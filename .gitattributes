# Force les fins de ligne Unix (LF) pour les fichiers exécutés sur le serveur Linux,
# même si le dépôt est édité sous Windows (sinon les scripts bash ne démarrent pas).
*.sh            text eol=lf
Caddyfile       text eol=lf
*.service       text eol=lf
*.env           text eol=lf
*.env.example   text eol=lf
