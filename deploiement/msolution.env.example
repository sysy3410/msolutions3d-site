# ============================================================
#  Variables d'environnement de l'application
#  1. Copiez ce fichier en "msolution.env" (sur le serveur)
#  2. Remplissez vos valeurs réelles
#  3. Protégez-le :  chmod 600 msolution.env
# ============================================================

# E-mail du compte administrateur (= identifiant de connexion à /admin.html).
# À définir AVANT le tout premier démarrage.
MSOLUTION_ADMIN_EMAIL=contact@msolutions3d.fr

# --- Envoi d'e-mails réels via Brevo (SMTP) ---
# Tant que ces variables ne sont pas remplies, les e-mails restent en mode
# "développement" (journalisés dans backend/data/emails_dev.log, non envoyés).
MSOLUTION_SMTP_HOST=smtp-relay.brevo.com
MSOLUTION_SMTP_PORT=587
MSOLUTION_SMTP_USER=VOTRE_LOGIN_SMTP_BREVO
MSOLUTION_SMTP_PASSWORD=VOTRE_CLE_SMTP_BREVO
MSOLUTION_SMTP_FROM=contact@msolutions3d.fr

# --- Statistiques de visites (Umami) — facultatif ---
# Origine du service Umami, autorisée par la politique de sécurité (CSP).
# Cloud :        https://cloud.umami.is
# Auto-hébergé : https://stats.msolutions3d.fr
# (Laisser vide si vous n'utilisez pas de statistiques.)
MSOLUTION_ANALYTICS_ORIGIN=
